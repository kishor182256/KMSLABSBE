PROJECT_NAME="AI Voice Studio"
VERSION="0.1.0"
API_PREFIX="/api/v1"
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
UPLOAD_DIR="uploaded_voice_samples"
VOICES_DIR="voice_profiles"
OUTPUT_DIR="generated_audio_outputs"
TEMP_DIR="temporary_processing_files"
METADATA_DIR="temporary_processing_files/metadata"
DEFAULT_VOICE_ENGINE="f5_tts"
XTTS_MODEL_NAME="tts_models/multilingual/multi-dataset/xtts_v2"
XTTS_DEVICE="auto"
F5_TTS_MODEL_NAME="F5TTS_v1_Base"
F5_TTS_DEVICE="auto"
F5_TTS_CACHE_DIR=
F5_TTS_ALLOW_AUTO_TRANSCRIPTION=true
F5_TTS_DEFAULT_REFERENCE_TEXT="This is a reference voice sample for voice cloning."
F5_TTS_MAX_CHUNK_CHARACTERS=350
F5_TTS_PARALLEL_WORKERS=1
INDIC_F5_MODEL_NAME="ai4bharat/IndicF5"
INDIC_F5_DEVICE="auto"
INDIC_F5_CACHE_DIR=
INDIC_F5_MAX_CHUNK_CHARACTERS=180
HUGGINGFACE_TOKEN=
HF_TOKEN=
FFMPEG_BINARY_PATH=C:/ffmpeg/ffmpeg-8.0.1-full_build-shared/bin/ffmpeg.exe
FFPROBE_BINARY_PATH=C:/ffmpeg/ffmpeg-8.0.1-full_build-shared/bin/ffprobe.exe
